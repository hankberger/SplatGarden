# Copy to .env and fill in. Never commit the real .env.

# --- Database (Google Cloud SQL for PostgreSQL) ---
# Local dev via the Cloud SQL Auth Proxy (run the proxy on :5432):
DATABASE_URL=postgresql://USER:PASSWORD@localhost:5432/DBNAME
# Cloud Run (Unix socket from the built-in Cloud SQL connection):
# DATABASE_URL=postgresql://USER:PASSWORD@/DBNAME?host=/cloudsql/PROJECT:REGION:INSTANCE

# --- Better Auth ---
# Random secret (generate with: openssl rand -base64 32)
BETTER_AUTH_SECRET=replace-with-a-long-random-string
# Browser-facing base URL. Dev = the Vite origin (proxied to Express).
BETTER_AUTH_URL=http://localhost:5173
# Prod example: https://your-app-xxxx.run.app

# Comma-separated origins allowed to call the auth API (CSRF).
TRUSTED_ORIGINS=http://localhost:5173

# --- Google OAuth (optional until configured; email/password works without it) ---
# Create at https://console.cloud.google.com/apis/credentials (OAuth client, type "Web application").
# Authorized redirect URI must be: <BETTER_AUTH_URL>/api/auth/callback/google
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# --- GCS uploads (direct browser-to-bucket via v4 signed URLs) ---
# Bucket must have CORS set for your frontend origin. Leave blank to disable
# uploads (the API will return uploadUrl: null and just record job metadata).
GCS_UPLOADS_BUCKET=
# Signer service account. Caller (user locally / runtime SA in prod) needs
# roles/iam.serviceAccountTokenCreator on this SA; the SA needs the same role
# on itself (so it can call signBlob as itself); and storage.objectAdmin on
# the bucket. Requires the IAM Credentials API.
GCS_SIGNER_SA=
