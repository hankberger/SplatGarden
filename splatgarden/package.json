{
  "name": "splatgarden",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "concurrently -n proxy,vite,api -c magenta,cyan,green \"npm:db:proxy\" \"vite\" \"npm:dev:server\"",
    "dev:server": "tsx watch server/index.ts",
    "db:proxy": "cloud-sql-proxy.exe splatgarden:us-central1:splatgarden-db --port 5433",
    "build": "tsc -b && vite build",
    "start": "cross-env NODE_ENV=production tsx server/index.ts",
    "auth:generate": "better-auth generate --config server/auth.ts --output server/schema.sql",
    "auth:migrate": "better-auth migrate --config server/auth.ts",
    "lint": "eslint .",
    "preview": "vite preview"
  },
  "dependencies": {
    "better-auth": "^1.6.11",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "pg": "^8.21.0",
    "react": "^19.2.6",
    "react-dom": "^19.2.6"
  },
  "devDependencies": {
    "@better-auth/cli": "^1.4.21",
    "@eslint/js": "^10.0.1",
    "@types/express": "^5.0.6",
    "@types/node": "^24.12.3",
    "@types/pg": "^8.20.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "concurrently": "^9.2.1",
    "cross-env": "^10.1.0",
    "eslint": "^10.3.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.6.0",
    "tsx": "^4.22.3",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.59.2",
    "vite": "^8.0.12"
  }
}
